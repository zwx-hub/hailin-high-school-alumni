# 后端端口：本地测试默认 3000
PORT=3000

# 允许访问接口的前端网站地址。上线后建议改成你的 GitHub Pages 地址。
# 多个地址用英文逗号隔开；测试阶段可暂时用 *
CORS_ORIGIN=https://zxw-hub.github.io

# 管理员登录账号密码。上线前必须改强密码。
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# 用于签发后台登录 token。上线前改成一串长随机字符。
TOKEN_SECRET=replace-with-a-long-random-secret

# 数据文件保存位置
DATA_FILE=./data/applications.json
